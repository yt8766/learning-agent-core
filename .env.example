# .env.example — 复制为 .env 并按需修改
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=agent_db

# Knowledge retrieval production wiring
# Modes: keyword-only | vector-only | hybrid
KNOWLEDGE_RETRIEVAL_MODE=hybrid

# Keyword provider: leave empty for local snapshot keyword search, or use opensearch.
KNOWLEDGE_KEYWORD_PROVIDER=opensearch
KNOWLEDGE_OPENSEARCH_ENDPOINT=http://localhost:9200
KNOWLEDGE_OPENSEARCH_INDEX=knowledge-chunks
KNOWLEDGE_OPENSEARCH_API_KEY=

# Vector provider: leave empty/off for keyword-only, or use chroma.
KNOWLEDGE_VECTOR_PROVIDER=chroma
KNOWLEDGE_VECTOR_ENABLED=true
KNOWLEDGE_CHROMA_ENDPOINT=http://localhost:8000
KNOWLEDGE_CHROMA_COLLECTION=runtime-knowledge
KNOWLEDGE_CHROMA_API_KEY=

# Embedding provider used by Chroma query-time vector search.
KNOWLEDGE_EMBEDDINGS_ENDPOINT=http://localhost:8080/v1/embeddings
KNOWLEDGE_EMBEDDINGS_MODEL=embedding-3
KNOWLEDGE_EMBEDDINGS_API_KEY=
KNOWLEDGE_EMBEDDINGS_DIMENSIONS=

# Provider health guardrails for /health and Runtime Center.
KNOWLEDGE_PROVIDER_HEALTH_TTL_MS=5000
KNOWLEDGE_PROVIDER_HEALTH_TIMEOUT_MS=2000
KNOWLEDGE_PROVIDER_HEALTH_DEGRADED_AFTER_FAILURES=1
