/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# 项目本地数据（legacy import 输入、profile storage、运行时生成、大文件等）
# -----------------------------------------------------------------------------
/tmp
# Root data is legacy import input only. Current runtime storage uses
# profile-storage/* and artifacts/* instead.
/data/runtime
/data/memory
/data/knowledge
/data/skills
/data/skill-runtime
/profile-storage/**
.db
/db
data/**/*.tmp
packages/templates/src/*.d.ts
packages/templates/src/*.d.ts.map
packages/*/src/**/*.d.ts.map
agents/*/src/**/*.d.ts.map
!packages/templates/src/bonus-center-data/services/
!packages/templates/src/bonus-center-data/services/data/
!packages/templates/src/bonus-center-data/services/data/bonusCenter.ts
!packages/templates/src/bonus-center-data/types/
!packages/templates/src/bonus-center-data/types/data/
.superpowers
!packages/templates/src/bonus-center-data/types/data/bonusCenter.ts

