{
  "name": "@agent/agents-supervisor",
  "version": "0.1.0",
  "main": "build/cjs/index.js",
  "module": "build/esm/index.mjs",
  "types": "build/types/agents/supervisor/src/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./build/types/agents/supervisor/src/index.d.ts",
        "default": "./build/esm/index.mjs"
      },
      "require": {
        "types": "./build/types/agents/supervisor/src/index.d.ts",
        "default": "./build/cjs/index.js"
      }
    }
  },
  "scripts": {
    "build:transpile": "tsup",
    "build:types": "tsc -p tsconfig.types.json",
    "build:watch": "tsup --watch",
    "build:watch:types": "tsc -p tsconfig.types.json --watch",
    "watch": "pnpm build:watch & pnpm build:watch:types",
    "build:lib": "pnpm build:transpile && pnpm build:types",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "turbo:typecheck": "node ../../scripts/run-package-typecheck.js agents/supervisor",
    "test": "pnpm --dir ../.. exec vitest run --config vitest.config.js agents/supervisor/test --exclude '**/*.int-spec.ts' --exclude '**/*.int-spec.tsx'",
    "turbo:test:unit": "pnpm test",
    "test:integration": "node ../../scripts/run-package-integration-tests.js agents/supervisor",
    "turbo:test:integration": "pnpm test:integration",
    "verify": "pnpm typecheck && pnpm test && pnpm test:integration && pnpm build:lib"
  },
  "dependencies": {
    "@agent/adapters": "workspace:*",
    "@agent/agent-kit": "workspace:*",
    "@agent/agents-coder": "workspace:*",
    "@agent/agents-reviewer": "workspace:*",
    "@agent/core": "workspace:*",
    "@langchain/langgraph": "^1.2.5",
    "zod": "^4.3.6"
  }
}
