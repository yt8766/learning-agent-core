{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:server": "tsc -p tsconfig.build.json",
    "cleanup:artifacts": "node ./scripts/cleanup-agent-server-artifacts.mjs",
    "cleanup:artifacts:dry-run": "node ./scripts/cleanup-agent-server-artifacts.mjs --dry-run",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prestart": "pnpm --dir ../../.. build:lib",
    "start": "nest start",
    "prestart:dev": "pnpm --dir ../../.. build:lib",
    "start:dev": "nest start --watch",
    "dev:backend": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "turbo:typecheck": "pnpm typecheck",
    "test": "pnpm --dir ../../.. exec vitest run --config vitest.config.js apps/backend/agent-server/test",
    "turbo:test:unit": "pnpm --dir ../../.. exec vitest run --config vitest.config.js apps/backend/agent-server/test --exclude '**/*.int-spec.ts' --exclude '**/*.int-spec.tsx'",
    "test:runtime": "pnpm --dir ../../.. exec vitest run apps/backend/agent-server/src/runtime apps/backend/agent-server/test/runtime",
    "turbo:test:integration": "node ../../../scripts/run-package-integration-tests.js apps/backend/agent-server",
    "test:watch": "pnpm --dir ../../.. exec vitest --config vitest.config.js apps/backend/agent-server/test",
    "test:cov": "pnpm --dir ../../.. exec vitest run --config vitest.config.js apps/backend/agent-server/test --coverage",
    "test:debug": "pnpm --dir ../../.. exec vitest --config vitest.config.js apps/backend/agent-server/test --inspect-brk"
  },
  "dependencies": {
    "@agent/adapters": "workspace:*",
    "@agent/agents-coder": "workspace:*",
    "@agent/agents-company-live": "workspace:*",
    "@agent/agents-data-report": "workspace:*",
    "@agent/agents-intel-engine": "workspace:*",
    "@agent/agents-reviewer": "workspace:*",
    "@agent/agents-supervisor": "workspace:*",
    "@agent/config": "workspace:*",
    "@agent/core": "workspace:*",
    "@agent/evals": "workspace:*",
    "@agent/knowledge": "workspace:*",
    "@agent/memory": "workspace:*",
    "@agent/platform-runtime": "workspace:*",
    "@agent/runtime": "workspace:*",
    "@agent/skill": "workspace:*",
    "@agent/templates": "workspace:*",
    "@agent/tools": "workspace:*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "^10.0.2",
    "bree": "^9.2.9",
    "chalk": "4",
    "dayjs": "^1.11.13",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "shelljs": "^0.8.5",
    "typeorm": "^0.3.20",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/shelljs": "^0.8.17",
    "@types/supertest": "^6.0.2",
    "globals": "^16.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
