{
  "name": "agent-chat",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "turbo:typecheck": "pnpm typecheck",
    "turbo:test:unit": "pnpm --dir ../../.. exec vitest run --config vitest.config.js apps/frontend/agent-chat/test --exclude '**/*.int-spec.ts' --exclude '**/*.int-spec.tsx'",
    "turbo:test:integration": "node ../../../scripts/run-package-integration-tests.js apps/frontend/agent-chat",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@agent/core": "workspace:*",
    "@ant-design/icons": "~6.1.0",
    "@ant-design/x": "^2.4.0",
    "@ant-design/x-markdown": "^2.4.0",
    "@ant-design/x-sdk": "^2.4.0",
    "@tanstack/react-query": "^5.99.1",
    "antd": "^6.3.3",
    "axios": "^1.13.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "postcss-preset-env": "^11.2.0",
    "sass": "^1.98.0",
    "vite": "^8.0.1"
  }
}
