{
  "name": "agent-gateway",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "turbo:typecheck": "pnpm typecheck",
    "turbo:test:unit": "pnpm --dir ../../.. exec vitest run --config vitest.config.js apps/frontend/agent-gateway/test --exclude '**/*.int-spec.ts' --exclude '**/*.int-spec.tsx'",
    "turbo:test:integration": "node ../../../scripts/run-package-integration-tests.js apps/frontend/agent-gateway"
  },
  "dependencies": {
    "@agent/core": "workspace:*",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@tanstack/react-query": "^5.99.1",
    "@uiw/react-codemirror": "^4.25.9",
    "axios": "^1.13.6",
    "i18next": "^25.10.10",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "motion-dom": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.14.2",
    "vite-plugin-singlefile": "^2.3.3",
    "yaml": "^2.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "sass": "^1.98.0",
    "typescript": "^5.8.2",
    "vite": "^8.0.1"
  }
}
