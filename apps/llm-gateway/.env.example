# Local database. Start it with:
# pnpm --dir apps/llm-gateway docker:up
POSTGRES_DB=llm_gateway
POSTGRES_USER=llm_gateway
POSTGRES_PASSWORD=llm_gateway_password
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=./.db/postgres

# Keep this aligned with the POSTGRES_* values above for the app runtime.
DATABASE_URL=postgresql://llm_gateway:llm_gateway_password@localhost:5432/llm_gateway

# Redis is required by gateway runtime/rate-limit deployment. Point this at the
# local or managed Redis instance used by the environment.
REDIS_URL=redis://localhost:6379/0

# Provider API keys. Leave a provider blank only if that provider is disabled.
OPENAI_API_KEY=
MINIMAX_API_KEY=
MIMO_API_KEY=

# Private bootstrap key for /v1/* before managed virtual keys are created.
LLM_GATEWAY_BOOTSTRAP_API_KEY=replace-with-local-bootstrap-api-key

# Admin login bootstrap. Replace both placeholders before starting the app:
# values beginning with replace-with- are treated as not configured.
# The first configured start persists admin principals, credentials, attempts,
# and audit events in PostgreSQL. Later changes do not overwrite an existing
# owner password; use the change-password route or reset local PostgreSQL data.
LLM_GATEWAY_BOOTSTRAP_ADMIN_PASSWORD=replace-with-local-admin-password
LLM_GATEWAY_ADMIN_JWT_SECRET=replace-with-at-least-32-random-characters
