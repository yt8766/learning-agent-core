# Local database. Start the root Postgres service from the repository root:
# docker compose up -d postgres
# Keep this aligned with the root .env / .env.example DB_* values.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_db

# Upstash Redis is the recommended production limiter backend on Vercel.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional Redis URL for non-Upstash/local deployments. Current production
# bootstrap runtime fails closed unless Upstash REST credentials are configured.
REDIS_URL=redis://localhost:6379/0

# Provider API keys. Leave a provider blank only if that provider is disabled.
# These are bootstrap seed values; managed provider credentials should be stored
# encrypted once the provider/model admin pages are enabled.
OPENAI_API_KEY=
MINIMAX_API_KEY=
MIMO_API_KEY=

# Required before provider credentials are persisted by the admin console.
LLM_GATEWAY_PROVIDER_SECRET_KEY=replace-with-at-least-32-random-characters
LLM_GATEWAY_PROVIDER_SECRET_KEY_VERSION=env-v1

# Private bootstrap key for /v1/* before managed virtual keys are created.
LLM_GATEWAY_BOOTSTRAP_API_KEY=replace-with-local-bootstrap-api-key

# Required when DB-backed virtual API keys are used.
LLM_GATEWAY_KEY_HASH_SECRET=replace-with-at-least-32-random-characters

# Admin login bootstrap. The local default account is admin.
# The first configured start persists admin principals, credentials, attempts,
# and audit events in PostgreSQL. Later changes do not overwrite an existing
# owner password; use the change-password route or reset local PostgreSQL data.
# The first app login with admin / <configured-password> persists the owner record in PostgreSQL.
LLM_GATEWAY_BOOTSTRAP_ADMIN_PASSWORD=replace-with-local-admin-password
LLM_GATEWAY_ADMIN_JWT_SECRET=replace-with-at-least-32-random-characters
