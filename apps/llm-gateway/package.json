{
  "name": "llm-gateway",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "test:e2e": "node scripts/run-e2e.mjs --runner=container",
    "test:e2e:local": "node scripts/run-e2e.mjs --runner=host",
    "test:e2e:up": "docker compose -p ${LLM_GATEWAY_E2E_PROJECT:-llm-gateway-e2e} -f docker-compose.e2e.yml up -d llm-gateway-e2e-postgres llm-gateway-e2e-app",
    "test:e2e:down": "docker compose -p ${LLM_GATEWAY_E2E_PROJECT:-llm-gateway-e2e} -f docker-compose.e2e.yml down -v --remove-orphans --rmi local",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "turbo:typecheck": "pnpm typecheck",
    "turbo:test:unit": "pnpm --dir ../.. exec vitest run --config vitest.config.js apps/llm-gateway/test --exclude '**/*.int-spec.ts'",
    "turbo:test:integration": "node ../../scripts/run-package-integration-tests.js apps/llm-gateway",
    "preview:smoke": "node scripts/preview-smoke.mjs",
    "lint": "eslint --ignore-pattern .next --ignore-pattern node_modules ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@next/env": "^16.0.0",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "^16.0.0",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "3.8.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
