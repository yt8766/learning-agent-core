{
  "name": "@agent/worker",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "build": "tsup src/main.ts --format cjs --dts --out-dir dist",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "turbo:typecheck": "node ../../scripts/run-package-typecheck.js apps/worker",
    "test": "pnpm --dir ../.. exec vitest run apps/worker/test",
    "turbo:test:unit": "pnpm test",
    "turbo:test:integration": "node ../../scripts/run-package-integration-tests.js apps/worker"
  },
  "dependencies": {
    "@agent/adapters": "workspace:*",
    "@agent/config": "workspace:*",
    "@agent/memory": "workspace:*",
    "@agent/runtime": "workspace:*",
    "@agent/skill-runtime": "workspace:*",
    "@agent/tools": "workspace:*"
  }
}
