{
  "name": "agent-brain-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "type": "module",
  "scripts": {
    "clean:lib": "node ./scripts/build.js clean --all",
    "build:lib": "turbo build:lib",
    "build:frontend": "turbo build --filter=agent-admin --filter=agent-chat --filter=codex-chat --filter=knowledge",
    "start:dev": "pnpm build:lib && turbo run start:dev --filter=server",
    "start:dev:agent": "pnpm --dir apps/backend/agent-server start:dev",
    "dev": "turbo dev",
    "docker:up:postgres": "docker compose up -d postgres",
    "docker:down": "docker compose down",
    "docker:ps": "docker compose ps",
    "docker:logs": "docker compose logs -f postgres",
    "docker:logs:postgrest": "docker compose logs -f postgrest",
    "docker:init:db": "docker compose exec -T postgres psql -U postgres -d agent_db < apps/backend/agent-server/src/knowledge/repositories/knowledge-schema.sql",
    "build": "turbo build",
    "check:staged": "node ./scripts/check-staged.js",
    "check:backend-structure": "node ./scripts/check-backend-structure.js",
    "check:barrel-layout": "node ./scripts/check-barrel-layout.js",
    "check:no-root-data-runtime": "node ./scripts/check-no-root-data-runtime.mjs",
    "check:no-tracked-root-data": "node ./scripts/check-no-tracked-root-data.mjs",
    "check:package-boundaries": "node ./scripts/check-package-boundaries.js",
    "check:source-artifacts": "node ./scripts/check-source-artifacts.js",
    "check:docs": "node ./scripts/check-docs.js",
    "check:docs:turbo": "node ./scripts/run-turbo-tasks.js check:docs",
    "new:doc": "node ./scripts/new-doc.js",
    "check:architecture": "pnpm check:backend-structure && pnpm check:barrel-layout && pnpm check:package-boundaries && pnpm check:source-artifacts",
    "check:architecture:turbo": "node ./scripts/run-turbo-tasks.js check:architecture",
    "verify:governance": "node ./scripts/run-turbo-tasks.js check:docs check:architecture",
    "typecheck:affected": "node ./scripts/run-turbo-affected.js turbo:typecheck",
    "lint:prettier:check": "prettier --check \"**/*.{js,ts,mjs,cjs,json,tsx,css,less,scss,html,md}\"",
    "lint:eslint:check": "eslint --max-warnings=0 --ext .js,.ts,.tsx,.mjs,.cjs .",
    "lint:prettier:affected": "node ./scripts/run-affected-lint.js prettier",
    "lint:eslint:affected": "node ./scripts/run-affected-lint.js eslint",
    "test:spec:affected": "node ./scripts/run-spec-tests.js --affected",
    "test:unit:affected": "node ./scripts/run-turbo-affected.js turbo:test:unit",
    "test:demo:affected": "node ./scripts/run-turbo-affected.js demo",
    "test:integration:affected": "node ./scripts/run-turbo-affected.js turbo:test:integration",
    "test:workspace:integration:affected": "node ./scripts/run-workspace-integration-affected.js",
    "eval:prompts:affected": "node ./scripts/run-affected-prompt-regression.js",
    "verify:affected": "pnpm verify:governance && pnpm lint:prettier:affected && pnpm lint:eslint:affected && pnpm test:spec:affected && pnpm typecheck:affected && pnpm test:unit:affected && pnpm test:demo:affected && pnpm test:integration:affected && pnpm test:workspace:integration:affected",
    "check:terminology": "node ./scripts/check-terminology.js",
    "typecheck": "pnpm lint:tsc",
    "lint:tsc": "node scripts/typecheck.js",
    "lint:prettier": "prettier --write \"**/*.{js,ts,mjs,cjs,json,tsx,css,less,scss,html,md}\"",
    "lint:eslint": "eslint --fix --ext .js,.ts,.tsx,.mjs,.cjs .",
    "prepare": "husky",
    "test": "vitest run --config vitest.config.js",
    "test:spec": "node ./scripts/run-spec-tests.js",
    "test:unit": "vitest run --config vitest.config.js --exclude '**/*.int-spec.ts' --exclude '**/*.int-spec.tsx' --exclude '**/*.smoke.ts' --exclude '**/*.acc-spec.ts'",
    "test:demo": "node ./scripts/run-package-demos.js",
    "test:integration": "vitest run --config vitest.config.js int-spec",
    "test:workspace:integration": "vitest run --config vitest.config.js test/integration",
    "test:workspace:smoke": "vitest run --config vitest.config.js test/smoke",
    "test:coverage": "vitest run --config vitest.config.js --coverage",
    "test:watch": "vitest --config vitest.config.js",
    "eval:prompts": "node ./scripts/run-prompt-regression.js",
    "eval:prompts:view": "pnpm exec promptfoo view",
    "check": "pnpm lint:prettier && pnpm lint:eslint && pnpm test && pnpm lint:tsc && pnpm check:architecture",
    "verify": "pnpm check:docs && pnpm lint:prettier:check && pnpm lint:eslint:check && pnpm typecheck && pnpm test:spec && pnpm test:unit && pnpm test:demo && pnpm test:integration && pnpm test:workspace:integration && pnpm test:workspace:smoke && pnpm check:architecture"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.22.0",
    "@testing-library/react": "^16.3.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "promptfoo": "^0.121.5",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^4.1.2"
  }
}
