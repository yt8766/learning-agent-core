{
  "name": "@agent/knowledge",
  "version": "0.1.0",
  "main": "build/cjs/index.js",
  "module": "build/esm/index.mjs",
  "types": "build/types/knowledge/src/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./build/types/knowledge/src/index.d.ts",
        "default": "./build/esm/index.mjs"
      },
      "require": {
        "types": "./build/types/knowledge/src/index.d.ts",
        "default": "./build/cjs/index.js"
      }
    },
    "./node": {
      "import": {
        "types": "./build/types/knowledge/src/node/index.d.ts",
        "default": "./build/esm/node/index.mjs"
      },
      "require": {
        "types": "./build/types/knowledge/src/node/index.d.ts",
        "default": "./build/cjs/node/index.js"
      }
    },
    "./browser-entry": {
      "types": "./build/types/knowledge/src/browser/index.d.ts",
      "module": "./build/esm/browser/index.mjs",
      "browser": "./build/esm/browser/index.mjs",
      "development": "./build/esm/browser/index.mjs",
      "import": "./build/esm/browser/index.mjs",
      "require": "./build/cjs/browser/index.js",
      "default": "./build/esm/browser/index.mjs"
    }
  },
  "scripts": {
    "demo": "node --import tsx demo/smoke.ts",
    "build:transpile": "tsup",
    "build:types": "tsc -p tsconfig.types.json",
    "build:watch": "tsup --watch",
    "build:watch:types": "tsc -p tsconfig.types.json --watch",
    "watch": "pnpm build:watch & pnpm build:watch:types",
    "build:lib": "pnpm build:transpile && pnpm build:types",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "turbo:typecheck": "pnpm typecheck",
    "test": "pnpm --dir ../.. exec vitest run --config vitest.config.js packages/knowledge/test --exclude '**/*.int-spec.ts' --exclude '**/*.int-spec.tsx'",
    "turbo:test:unit": "pnpm test",
    "test:integration": "node ../../scripts/run-package-integration-tests.js packages/knowledge",
    "turbo:test:integration": "pnpm test:integration",
    "verify": "pnpm typecheck && pnpm test && pnpm test:integration && pnpm build:lib"
  },
  "dependencies": {
    "@agent/core": "workspace:*",
    "@agent/config": "workspace:*",
    "@agent/memory": "workspace:*",
    "@langchain/core": "^1.1.40",
    "@langchain/openai": "^1.4.1",
    "@langchain/textsplitters": "^1.0.1",
    "chromadb": "^3.4.3",
    "zod": "^4.3.6"
  }
}
