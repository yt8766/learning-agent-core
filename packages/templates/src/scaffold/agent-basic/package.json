{
  "name": "__PACKAGE_NAME__",
  "version": "0.1.0",
  "main": "build/cjs/index.js",
  "module": "build/esm/index.mjs",
  "types": "build/types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./build/types/index.d.ts",
        "default": "./build/esm/index.mjs"
      },
      "require": {
        "types": "./build/types/index.d.ts",
        "default": "./build/cjs/index.js"
      }
    }
  },
  "scripts": {
    "build:transpile": "tsup",
    "build:types": "tsc -p tsconfig.types.json",
    "build:watch": "tsup --watch",
    "build:watch:types": "tsc -p tsconfig.types.json --watch",
    "watch": "pnpm build:watch & pnpm build:watch:types",
    "build:lib": "pnpm build:transpile && pnpm build:types",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:spec": "node __REPO_ROOT_RELATIVE__/scripts/run-spec-tests.js __TARGET_ROOT_FROM_REPO__",
    "test": "pnpm --dir __REPO_ROOT_RELATIVE__ exec vitest run --config vitest.config.js __TARGET_ROOT_FROM_REPO__/test --exclude '**/*.int-spec.ts' --exclude '**/*.int-spec.tsx'",
    "test:integration": "node __REPO_ROOT_RELATIVE__/scripts/run-package-integration-tests.js __TARGET_ROOT_FROM_REPO__",
    "verify": "pnpm typecheck && pnpm test:spec && pnpm test && pnpm test:integration && pnpm build:lib"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
