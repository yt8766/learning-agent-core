{
  "name": "@agent/tools",
  "version": "0.1.0",
  "main": "build/cjs/index.js",
  "module": "build/esm/index.mjs",
  "types": "build/types/tools/src/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./build/types/tools/src/index.d.ts",
        "default": "./build/esm/index.mjs"
      },
      "require": {
        "types": "./build/types/tools/src/index.d.ts",
        "default": "./build/cjs/index.js"
      }
    },
    "./command": {
      "import": {
        "types": "./build/types/command/index.d.ts",
        "default": "./build/esm/command/index.mjs"
      },
      "require": {
        "types": "./build/types/command/index.d.ts",
        "default": "./build/cjs/command/index.js"
      }
    },
    "./executors/connectors": {
      "import": {
        "types": "./build/types/executors/connectors/connectors-executor.d.ts",
        "default": "./build/esm/executors/connectors/connectors-executor.mjs"
      },
      "require": {
        "types": "./build/types/executors/connectors/connectors-executor.d.ts",
        "default": "./build/cjs/executors/connectors/connectors-executor.js"
      }
    },
    "./executors/filesystem": {
      "import": {
        "types": "./build/types/executors/filesystem/filesystem-executor.d.ts",
        "default": "./build/esm/executors/filesystem/filesystem-executor.mjs"
      },
      "require": {
        "types": "./build/types/executors/filesystem/filesystem-executor.d.ts",
        "default": "./build/cjs/executors/filesystem/filesystem-executor.js"
      }
    },
    "./executors/runtime-governance": {
      "import": {
        "types": "./build/types/executors/runtime-governance/runtime-governance-executor.d.ts",
        "default": "./build/esm/executors/runtime-governance/runtime-governance-executor.mjs"
      },
      "require": {
        "types": "./build/types/executors/runtime-governance/runtime-governance-executor.d.ts",
        "default": "./build/cjs/executors/runtime-governance/runtime-governance-executor.js"
      }
    },
    "./executors/scaffold": {
      "import": {
        "types": "./build/types/executors/scaffold/scaffold-executor.d.ts",
        "default": "./build/esm/executors/scaffold/scaffold-executor.mjs"
      },
      "require": {
        "types": "./build/types/executors/scaffold/scaffold-executor.d.ts",
        "default": "./build/cjs/executors/scaffold/scaffold-executor.js"
      }
    },
    "./executors/scheduling": {
      "import": {
        "types": "./build/types/executors/scheduling/scheduling-executor.d.ts",
        "default": "./build/esm/executors/scheduling/scheduling-executor.mjs"
      },
      "require": {
        "types": "./build/types/executors/scheduling/scheduling-executor.d.ts",
        "default": "./build/cjs/executors/scheduling/scheduling-executor.js"
      }
    }
  },
  "scripts": {
    "demo": "node --import tsx demo/smoke.ts",
    "build:transpile": "tsup",
    "build:types": "tsc -p tsconfig.types.json",
    "build:watch": "tsup --watch",
    "build:watch:types": "tsc -p tsconfig.types.json --watch",
    "watch": "pnpm build:watch & pnpm build:watch:types",
    "build:lib": "pnpm build:transpile && pnpm build:types",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "turbo:typecheck": "pnpm typecheck",
    "test": "pnpm --dir ../.. exec vitest run --config vitest.config.js packages/tools/test --exclude '**/*.int-spec.ts' --exclude '**/*.int-spec.tsx'",
    "turbo:test:unit": "pnpm test",
    "test:integration": "node ../../scripts/run-package-integration-tests.js packages/tools",
    "turbo:test:integration": "pnpm test:integration",
    "verify": "pnpm typecheck && pnpm test && pnpm test:integration && pnpm build:lib"
  },
  "dependencies": {
    "@agent/config": "workspace:*",
    "@agent/core": "workspace:*",
    "@agent/memory": "workspace:*",
    "@agent/report-kit": "workspace:*",
    "@agent/runtime": "workspace:*",
    "@agent/templates": "workspace:*",
    "fs-extra": "^11.3.4",
    "zod": "^4.3.6"
  }
}
