{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@agent/shared": ["packages/shared/src"],
      "@agent/config": ["packages/config/src"],
      "@agent/tools": ["packages/tools/src"],
      "@agent/memory": ["packages/memory/src"],
      "@agent/skills": ["packages/skills/src"],
      "@agent/evals": ["packages/evals/src"],
      "@agent/agent-core": ["packages/agent-core/src"]
    }
  }
}
